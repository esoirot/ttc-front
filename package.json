{
  "name": "ttc-front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "circular": "madge --circular --extensions ts,tsx --ts-config tsconfig.app.json src/",
    "circular:warnings": "madge --circular --warning --extensions ts,tsx --ts-config tsconfig.app.json src/",
    "depcheck": "depcheck",
    "prune": "ts-prune",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --fix",
    "preview": "vite preview",
    "check": "pnpm run typecheck && pnpm run circular && pnpm run depcheck && pnpm run prune && pnpm run format:check && pnpm run lint && pnpm run test-storybook",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "vitest run --project=storybook --no-file-parallelism"
  },
  "dependencies": {
    "@apollo/client": "^4.1.9",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "graphql": "^16.14.0",
    "lucide-react": "^1.14.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "depcheck": {
    "ignores": [
      "tailwindcss",
      "@types/babel__core",
      "@fontsource-variable/geist",
      "tw-animate-css",
      "@chromatic-com/storybook",
      "@storybook/addon-a11y",
      "@storybook/addon-docs",
      "@storybook/addon-mcp"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-vitest": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tanstack/react-query-devtools": "^5.101.0",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.1.0",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.0.5",
    "@vitest/coverage-v8": "^4.0.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "depcheck": "^1.4.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.6",
    "globals": "^17.6.0",
    "jsdom": "^27.0.0",
    "madge": "^8.0.0",
    "playwright": "^1.61.0",
    "prettier": "^3.8.3",
    "storybook": "^10.4.6",
    "ts-prune": "^0.10.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.0.5"
  }
}
